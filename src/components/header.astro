<header
  class="sticky top-0 z-30 overflow-hidden border-b border-border/70 bg-bg/80 backdrop-blur-xl"
>
  <div class="container-shell grid min-h-18 grid-cols-[auto_1fr] items-center gap-4 py-4 md:grid-cols-[1fr_auto_1fr]">
    <div class="hidden md:block" aria-hidden="true"></div>

    <nav
      class="flex max-w-full flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-text-muted sm:gap-x-6 sm:text-base md:gap-8 md:text-sm"
    >
      <a href="/#catalog" class="hover:text-text">Catalog</a>
      <a href="/#patterns" class="hover:text-text">Patterns</a>
      <a href="/#snippets" class="hover:text-text">Snippets</a>
      <a href="/#why" class="hover:text-text">Why</a>
    </nav>

    <a
      href="https://github.com/bun-and-butter"
      target="_blank"
      rel="noreferrer"
      aria-label="Open the Bun & Butter GitHub organization"
      class="justify-self-end text-text-muted transition hover:text-text"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-6"
        aria-hidden="true"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d={githubMarkPath} />
      </svg>
    </a>
  </div>
</header>

---
interface FeatureItem {
	label: string;
	title: string;
	description: string;
}

interface Props {
	items: FeatureItem[];
}

const { items } = Astro.props;
---

<section class="container-shell section-space">
	<div class="grid gap-4 md:grid-cols-3">
		{
				items.map((item) => (
					<div class="glass-panel-soft p-6">
						<p class="text-sm uppercase tracking-widest text-text-muted">
							{item.label}
						</p>
					<p class="mt-3 text-2xl font-semibold text-text">
						{item.title}
					</p>
					<p class="mt-3 text-sm leading-6 text-text-muted">
						{item.description}
					</p>
				</div>
			))
		}
	</div>
</section>

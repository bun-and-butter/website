---
import { Image } from "astro:assets";
import logoImg from "../assets/logo.webp";
import CodeFrame from "./code-frame.astro";
---

<section class="container-shell pb-10 pt-12">
  <div class="grid gap-12 lg:justify-center">
    <div class="mx-auto w-full min-w-0 max-w-3xl text-center">
      <div class="flex justify-center">
        <Image
          loading="eager"
          width={600}
          src={logoImg}
          alt="Bun & Butter logo"
          class="w-52 max-w-full rounded-3xl border border-white/8 bg-black/18 object-cover p-2 shadow-[0_0_30px_rgba(255,203,92,0.16)] sm:w-60 lg:w-72"
        />
      </div>

      <h1
        class="mx-auto mt-8 max-w-4xl text-3xl font-semibold leading-tight tracking-tight text-balance sm:text-5xl lg:text-7xl"
      >
        What deserves
        <span class="text-brand-400">a place in the next pan.</span>
      </h1>

      <p
        class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-text-muted sm:text-xl"
      >
        Some things keep showing up in project after project: a helper, a
        pattern, a small snippet worth keeping around. Bun & Butter is where we
        collect those pieces, clean them up, and make them easy to reuse.
      </p>

      <CodeFrame
        title="main.ts"
        class="mx-auto mt-8 max-w-2xl text-left"
        contentClass="hero-code"
      >
        <pre
          class="block w-full max-w-full overflow-x-auto px-4 pb-5 pt-2 text-sm leading-tight text-white/84"><code><span class="hero-line"><span class="hero-ln">1</span><span><span class="hero-token-keyword">import</span> &#123; <span class="hero-token-fn">addMoreButter</span> &#125; <span class="hero-token-keyword">from</span> <span class="hero-token-string">"@bun-and-butter"</span>;</span></span>
<span class="hero-line"><span class="hero-ln">2</span><span /></span>
<span class="hero-line"><span class="hero-ln">3</span><span><span class="hero-token-keyword">const</span> awesomeProject = <span class="hero-token-fn">addMoreButter</span>(<span class="hero-token-string">"super productive"</span>);</span></span>
<span class="hero-line"><span class="hero-ln">4</span><span><span class="hero-token-fn">run</span>(awesomeProject);</span></span></code></pre>
      </CodeFrame>

      <div
        class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:flex-wrap sm:justify-center"
      >
        <a href="#catalog" class="button-brand w-full sm:w-auto"
          >Browse the catalog</a
        >
        <a
          href="#patterns"
          class="button-muted hero-patterns-link w-full sm:w-auto"
          >See the patterns</a
        >
        <a
          href="#snippets"
          class="button-muted hero-snippets-link w-full sm:w-auto"
          >Use the snippets</a
        >
        <a href="#why" class="button-muted w-full sm:w-auto"
          >Why?</a
        >
      </div>
    </div>
  </div>
</section>

<style>
  @reference "../styles/global.css";

  .hero-code {
    @apply text-white/84;
  }

  .hero-line {
    @apply min-w-max flex gap-2;
  }

  .hero-ln {
    @apply w-6 shrink-0 text-right text-white/28;
  }

  .hero-token-keyword {
    color: rgb(255 210 120 / 0.96);
  }

  .hero-token-string {
    color: rgb(255 243 196 / 0.92);
  }

  .hero-token-fn {
    color: rgb(255 176 79 / 0.96);
  }

  .hero-patterns-link {
    border-color: rgb(255 255 255 / 0.12) !important;
    background: rgb(255 255 255 / 0.05) !important;
  }

  .hero-patterns-link:hover {
    border-color: rgb(255 196 80 / 0.42) !important;
    background: rgb(255 196 80 / 0.16) !important;
    color: rgb(255 248 220 / 0.98) !important;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      0 12px 28px rgb(0 0 0 / 0.16);
  }

  .hero-snippets-link {
    border-color: rgb(255 255 255 / 0.12) !important;
    background: rgb(255 255 255 / 0.04) !important;
  }

  .hero-snippets-link:hover {
    border-color: rgb(255 255 255 / 0.24) !important;
    background: rgb(255 255 255 / 0.1) !important;
    color: rgb(255 255 255 / 0.96) !important;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      0 12px 28px rgb(0 0 0 / 0.14);
  }
</style>

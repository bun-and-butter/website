---
interface Props {
	rootId: string;
	command: string;
	copyLabel: string;
}

const { rootId, command, copyLabel } = Astro.props;
---

<div id="install" class="scroll-mt-16 sm:scroll-mt-16"></div>

<section data-install-root={rootId} class="glass-panel p-6 sm:p-8 lg:p-10">
	<div class="section-heading">
		<div>
			<div class="eyebrow">Install</div>
			<h2 class="mt-4 font-heading text-3xl text-text sm:text-4xl">
				Install from Git
			</h2>
		</div>
		<p class="text-base leading-7 text-text-muted wrap-anywhere">
			Bun & Butter packages are installed directly from the GitHub
			repository over SSH. This is the recommended install path for the
			current version. See the{" "}
			<a
				href="https://bun.com/docs/pm/cli/add#git-dependencies"
				target="_blank"
				rel="noreferrer"
			>
				Bun docs on Git dependencies
			</a>{" "}
			for the exact `bun add` behavior.
		</p>
	</div>

	<div class="mt-8 grid min-w-0 gap-4">
		<div class="install-card">
			<div class="install-command-row">
				<pre class="install-command">
					<code>{command}</code>
				</pre>
				<button
					type="button"
					class="copy-button"
					data-copy-text={command}
					aria-label={copyLabel}
				>
					<svg
						viewBox="0 0 24 24"
						class="size-4"
						aria-hidden="true"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<rect
							x="9"
							y="9"
							width="10"
							height="10"
							rx="2"
							stroke="currentColor"
							stroke-width="1.8"
						/>
						<path
							d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</button>
			</div>
		</div>
	</div>
</section>

<script is:inline define:vars={{ rootId }}>
	const installRoot = document.querySelector(
		`[data-install-root="${rootId}"]`,
	);

	if (installRoot instanceof HTMLElement) {
		installRoot.addEventListener("click", async (event) => {
			const button =
				event.target instanceof Element
					? event.target.closest("[data-copy-text]")
					: null;

			if (!(button instanceof HTMLButtonElement)) {
				return;
			}

			const text = button.dataset.copyText;
			if (!text) {
				return;
			}

			const previous = button.innerHTML;

			try {
				await navigator.clipboard.writeText(text);
				button.textContent = "Copied";
			} catch {
				button.textContent = "Failed";
			}

			window.setTimeout(() => {
				button.innerHTML = previous;
			}, 1200);
		});
	}
</script>

<style>
	@reference "../../styles/global.css";

	.install-card {
		@apply min-w-0 overflow-hidden rounded-2xl border border-white/6 bg-black/10 p-4;
	}

	.install-command-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
	}

	.install-command {
		@apply m-0 min-w-0 overflow-x-auto whitespace-nowrap rounded-2xl border border-white/8 bg-black/30 px-4 py-3 text-[0.8rem] leading-6 text-brand-200;
		box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.05);
		overscroll-behavior-x: contain;
		-webkit-overflow-scrolling: touch;
	}

	.install-command code {
		@apply inline-block min-w-max;
	}

	.copy-button {
		@apply inline-flex size-8 items-center justify-center rounded-lg border border-white/8 bg-white/4 text-text-muted transition hover:bg-white/8 hover:text-text;
	}
</style>

---
interface Props {
	repoId?: string;
	href?: string;
	label?: string;
	variant?: "full" | "corner" | "flag";
	ariaLabel?: string;
	class?: string;
	fullWidth?: boolean;
}

const {
	repoId,
	href,
	label = "View on GitHub",
	variant = "full",
	ariaLabel,
	class: className = "",
	fullWidth = variant === "full",
} = Astro.props;

const resolvedHref =
	href ?? (repoId ? `https://github.com/bun-and-butter/${repoId}` : null);

if (!resolvedHref) {
	throw new Error("GitHubButton requires either `repoId` or `href`.");
}

const isCorner = variant === "corner";
const isFlag = variant === "flag";
const resolvedAriaLabel =
	ariaLabel ?? (isCorner || isFlag ? `${repoId ?? label} on GitHub` : label);
const githubMarkPath =
	"M12 .5a11.5 11.5 0 0 0-3.637 22.41c.575.106.785-.25.785-.554 0-.274-.01-1-.015-1.963-3.192.694-3.867-1.538-3.867-1.538-.523-1.327-1.277-1.68-1.277-1.68-1.044-.714.08-.7.08-.7 1.154.081 1.761 1.185 1.761 1.185 1.026 1.758 2.692 1.25 3.348.956.104-.744.402-1.25.731-1.538-2.548-.29-5.226-1.274-5.226-5.67 0-1.252.448-2.277 1.183-3.079-.119-.29-.513-1.46.112-3.045 0 0 .964-.309 3.16 1.176a10.97 10.97 0 0 1 5.753 0c2.194-1.485 3.157-1.176 3.157-1.176.627 1.585.233 2.755.114 3.045.737.802 1.182 1.827 1.182 3.08 0 4.406-2.682 5.376-5.238 5.662.413.356.781 1.058.781 2.133 0 1.54-.014 2.78-.014 3.158 0 .307.207.665.79.552A11.5 11.5 0 0 0 12 .5Z";
---

<a
	href={resolvedHref}
	target="_blank"
	rel="noreferrer"
	aria-label={resolvedAriaLabel}
	class:list={[
		"github-button",
		className,
		isFlag
			? "github-flag"
			: isCorner
				? "github-corner"
				: [
						"github-button--full inline-flex items-center justify-center gap-2.5 rounded-xl border px-4 py-2 font-medium text-white transition",
						fullWidth && "w-full",
					],
	]}
>
	{
		isFlag ? (
			<>
				<svg
					viewBox="0 0 100 100"
					class="github-flag__shape"
					aria-hidden="true"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
				>
					<defs>
						<linearGradient
							id="github-flag-fill"
							x1="50"
							x2="50"
							y1="0"
							y2="100"
							gradientUnits="userSpaceOnUse"
						>
							<stop offset="0" stop-color="#2b3138" />
							<stop offset="1" stop-color="#161b22" />
						</linearGradient>
					</defs>
					<path d="M0 0H100V100L0 0Z" fill="url(#github-flag-fill)" />
				</svg>
				<svg
					viewBox="0 0 24 24"
					class="github-flag__icon"
					aria-hidden="true"
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path d={githubMarkPath} />
				</svg>
			</>
		) : (
			<>
				<svg
					viewBox="0 0 24 24"
					class:list={[
						isCorner
							? "size-[1.15rem] shrink-0"
							: "size-[0.95rem] shrink-0",
					]}
					aria-hidden="true"
					fill="currentColor"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path d={githubMarkPath} />
				</svg>

				{!isCorner && <span>{label}</span>}
			</>
		)
	}
</a>

<style>
	.github-button--full {
		border-color: rgb(87 96 106 / 0.78);
		background:
			radial-gradient(
				circle at 50% 0%,
				rgb(255 255 255 / 0.1),
				transparent 52%
			),
			linear-gradient(180deg, #30363d 0%, #24292f 100%);
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.18),
			0 10px 24px rgb(0 0 0 / 0.2);
	}

	.github-corner {
		position: absolute;
		bottom: 0;
		right: 0;
		z-index: 20;
		display: inline-flex;
		height: 2.9rem;
		width: 2.9rem;
		align-items: center;
		justify-content: center;
		border-left: 1px solid rgb(255 255 255 / 0.08);
		border-top: 1px solid rgb(255 255 255 / 0.08);
		border-top-left-radius: 1.1rem;
		background:
			radial-gradient(
				circle at 50% 0%,
				rgb(255 255 255 / 0.09),
				transparent 55%
			),
			linear-gradient(180deg, #24292f 0%, #161b22 100%);
		color: white;
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.09),
			0 0 24px rgb(22 27 34 / 0.24);
		transition:
			transform 150ms ease,
			background 150ms ease;
	}

	.github-corner:hover {
		transform: scale(1.03);
		background:
			radial-gradient(
				circle at 50% 0%,
				rgb(255 255 255 / 0.07),
				transparent 55%
			),
			linear-gradient(180deg, #1f242b 0%, #0d1117 100%);
	}

	.github-flag {
		position: absolute;
		right: 0;
		top: 0;
		display: block;
		height: 4.45rem;
		width: 4.45rem;
		overflow: hidden;
		color: white;
		backface-visibility: hidden;
		transform: translateZ(0);
		transition: opacity 150ms ease;
	}

	.github-flag:hover {
		opacity: 0.96;
	}

	.github-flag__shape {
		position: absolute;
		inset: 0;
		display: block;
		height: 100%;
		width: 100%;
		filter: drop-shadow(0 10px 24px rgb(0 0 0 / 0.18));
	}

	.github-flag__icon {
		position: absolute;
		right: 0.28rem;
		top: 0.18rem;
		margin-top: 0.12rem;
		height: 1.6rem;
		width: 1.6rem;
		filter: drop-shadow(0 0 8px rgb(255 255 255 / 0.08));
	}

	.github-button--full:hover {
		background: linear-gradient(
			180deg,
			#24292f 0%,
			#1b1f23 100%
		) !important;
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.12),
			0 10px 24px rgb(0 0 0 / 0.22);
	}
</style>
